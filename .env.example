# =============================================================================
# Wispoke API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# --- Required: Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# --- Required: JWT ---
JWT_SECRET_KEY=generate-a-64-char-hex-secret-with-openssl-rand-hex-32

# --- Required: Pinecone (vector store) ---
PINECONE_API_KEY=your-pinecone-api-key

# --- Required: Cohere (embeddings) ---
COHERE_API_KEY=your-cohere-api-key

# --- Required: At least one LLM provider ---
GROQ_API_KEY=your-groq-api-key
# OPENAI_API_KEY=your-openai-api-key

# --- Optional: Voice Agent (Deepgram + Gemini Live) ---
# DEEPGRAM_API_KEY is used by the legacy Deepgram → Groq → Deepgram pipeline
# (and is required for Twilio calls — Gemini Live needs 16/24kHz, Twilio is 8kHz).
# GEMINI_API_KEY enables the speech-to-speech browser pipeline. Free tier from
# Google AI Studio: https://aistudio.google.com/apikey
# DEEPGRAM_API_KEY=your-deepgram-api-key
# GEMINI_API_KEY=your-gemini-api-key

# --- Optional: Google OAuth ---
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Optional: LemonSqueezy (payments) ---
# LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
# LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret
# LEMONSQUEEZY_STORE_ID=your-store-id
# LEMONSQUEEZY_VARIANT_ID=your-pro-plan-variant-id
# ADMIN_DASHBOARD_URL=https://your-admin-dashboard.vercel.app

# --- Optional: App settings ---
# EMBEDDING_MODEL=embed-english-v3.0
# BASE_DOMAIN=mysite.com
# CHATBOT_PROTOCOL=https
# USE_SUBDOMAIN_ROUTING=true

# --- Email (Resend) — get a key at https://resend.com/api-keys ---
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
