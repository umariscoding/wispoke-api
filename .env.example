# =============================================================================
# ChatEvo API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# --- Required: Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# --- Required: JWT ---
JWT_SECRET_KEY=generate-a-64-char-hex-secret-with-openssl-rand-hex-32

# --- Required: Pinecone (vector store) ---
PINECONE_API_KEY=your-pinecone-api-key

# --- Required: Cohere (embeddings) ---
COHERE_API_KEY=your-cohere-api-key

# --- Required: At least one LLM provider ---
GROQ_API_KEY=your-groq-api-key
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Optional: LangSmith tracing ---
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=your-langsmith-api-key
# LANGSMITH_PROJECT=your-project-name

# --- Optional: App settings ---
# EMBEDDING_MODEL=embed-english-v3.0
# BASE_DOMAIN=mysite.com
# CHATBOT_PROTOCOL=https
# USE_SUBDOMAIN_ROUTING=true
# DEBUG=false
# LOG_LEVEL=INFO
